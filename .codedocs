# CodeDocs.xyz configuration, see https://codedocs.xyz
#
# libConfuse ships a doc/Doxyfile.in template that needs ./configure, which
# CodeDocs cannot run, so the relevant Doxygen options are set directly here.

TAGLINKS =

PROJECT_NAME  = "libConfuse"
PROJECT_BRIEF = "Small configuration file parser library for C"

# C library: the public API lives in confuse.h, documented in confuse.c.
# README.md becomes the docs landing page (same as on GitHub).
OPTIMIZE_OUTPUT_FOR_C  = YES
INPUT                  = README.md doc/tutorial.md HACKING.md ChangeLog.md src/confuse.h src/confuse.c
USE_MDFILE_AS_MAINPAGE = README.md

# Render the example programs referenced with @example in confuse.h and
# @include in the tutorial, and let the reader browse the annotated source.
EXAMPLE_PATH   = examples doc
SOURCE_BROWSER = YES

# Hide the internal __CFG_* helper macros and the build-only DLLIMPORT/__export
# markers; only the public CFG_* API is documented.
EXCLUDE_SYMBOLS = __CFG_* DLLIMPORT __export

# Cap the content column width on wide screens, see doc/codedocs.css.
HTML_EXTRA_STYLESHEET = doc/codedocs.css
