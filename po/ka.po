#: src/confuse.c:339 src/confuse.c:360 src/confuse.c:3149
#, c-format
msgid "no such option '%s'"
msgstr "უცნობი პარამეტრი: '%s'"

#: src/confuse.c:341
#, c-format
msgid "no sub-section '%s' in '%s'"
msgstr "'%2$s'-ში ქვესექცია '%1$s' არ არსებობს"

#: src/confuse.c:343
#, c-format
msgid "no sub-section title/index for '%s'"
msgstr "'%s'-სთვის ქვესექციის სათაური/ინდექსი არ არსებობს"

#: src/confuse.c:977
#, c-format
msgid "duplicate option '%s' not allowed"
msgstr "პარამეტრის '%s' გამეორება დაშვებული არაა"

#: src/confuse.c:1236
#, c-format
msgid "found duplicate title '%s'"
msgstr "ნაპოვნია დუბლირებული სათაური '%s'"

#: src/confuse.c:1268 src/confuse.c:1300 src/confuse.c:1358
#, c-format
msgid "invalid integer value for option '%s'"
msgstr "არასწორი მთელი რიცხვის მნიშვნელობა პარამეტრისთვის '%s'"

#: src/confuse.c:1273 src/confuse.c:1305 src/confuse.c:1320 src/confuse.c:1363
#: src/confuse.c:1378
#, c-format
msgid "integer value for option '%s' is out of range"
msgstr "მთელი რიცხვის მნიშვნელობა პარამეტრისთვის '%s' დასაშვებ დიაპაზონს გარეთაა"

#: src/confuse.c:1350
#, c-format
msgid "negative value for unsigned option '%s'"
msgstr "უარყოფითი მნიშვნელობა უნიშნო პარამეტრისთვის '%s'"

#: src/confuse.c:1402
#, c-format
msgid "invalid floating point value for option '%s'"
msgstr "არასწორი მცურავწერტილიანი მნიშვნელობა პარამეტრისთვის '%s'"

#: src/confuse.c:1406
#, c-format
msgid "floating point value for option '%s' is out of range"
msgstr "მცურავწერტილიანი მნიშვნელობა პარამეტრისთვის '%s' დიაპაზონს გარეთაა"

#: src/confuse.c:1548
#, c-format
msgid "invalid boolean value for option '%s'"
msgstr "არასწორი ლოგიკური მნიშვნელობა პარამეტრისთვის '%s'"

#: src/confuse.c:1746
#, c-format
msgid "dropping deprecated configuration option '%s'"
msgstr "მოძველებული კონფიგურაციის პარამეტრის '%s' მოცილება"

#: src/confuse.c:1749
#, c-format
msgid "found deprecated option '%s', please update configuration file."
msgstr "ნაპოვნია მოძველებული პარამეტრი '%s'. განაახლეთ კონფიგურაციის ფაილი."

#: src/confuse.c:1773
#, c-format
msgid "too deeply nested sections (max %d), bailing out to avoid stack exhaustion"
msgstr "მეტისმეტად ბევრი ერთმანეთში ჩალაგებული სექცია (მაქს %d) სტეკის გადავსების თავიდან ასაცილებლად პროცესი შეწყდება"

#: src/confuse.c:1789
msgid "premature end of file"
msgstr "ფაილის ნაადრევი დასასრული"

#: src/confuse.c:1824
msgid "unexpected closing brace"
msgstr "მოულოდნელი დამხურავი ფრჩხილი"

#: src/confuse.c:1836 src/confuse.c:1918 src/confuse.c:1945 src/confuse.c:1968
#: src/confuse.c:2107 src/confuse.c:2153
#, c-format
msgid "unexpected token '%s'"
msgstr "მოულოდნელი ტოკენი '%s'"

#: src/confuse.c:1880
#, c-format
msgid "attempt to append to non-list option '%s'"
msgstr "სიის ტიპის არმქონე პარამეტრისთვის '%s' ბოლოში მიწერის მცდელობა"

#: src/confuse.c:1893
#, c-format
msgid "missing equal sign after option '%s'"
msgstr "პარამეტრის '%s' შემდეგ ტოლობის ნიშანი აკლია"

#: src/confuse.c:1975
#, c-format
msgid "missing opening brace for section '%s'"
msgstr "გამხსნელი ფრჩხილი სექციისთვის '%s' აუცილებელია"

#: src/confuse.c:2016
#, c-format
msgid "missing title for section '%s'"
msgstr "სათაური სექციისთვის '%s' აუცილებელია"

#: src/confuse.c:2028
#, c-format
msgid "missing parenthesis for function '%s'"
msgstr "ფუნქციას '%s' ფრჩხილი აკლია"

#: src/confuse.c:2055 src/confuse.c:2073
#, c-format
msgid "syntax error in call of function '%s'"
msgstr "სინტაქსური შეცდომა ფუნქციის '%s' გამოძახებისას"

#: src/confuse.c:2170
#, c-format
msgid "Internal error in cfg_parse_internal(), unknown state %d"
msgstr "cfg_parse_intenal()-ის შიდა შეცდომა. უცნობი მდგომარეობა %d"

#: src/confuse.c:2546
msgid "wrong number of arguments to cfg_include()"
msgstr "cfg_include()-ის არგუმენტების რიცხვი არასწორია"

#: src/lexer.l:180
#, c-format
msgid "invalid octal number '%s'"
msgstr "'%s' არასწორი რვაობითი რიცხვია"

#: src/lexer.l:186
#, c-format
msgid "bad escape sequence '%s'"
msgstr "არასწორი სპეციალური მიმდევრობა '%s'"

#: src/lexer.l:257
msgid "unterminated string constant"
msgstr "დაუსრულებელი სტრიქონი კონსტანტა"

#: src/lexer.l:389
msgid "includes nested too deeply"
msgstr "ერთმანეთში ჩასმების სიღრმე მეტისმეტად დიდია"

#: src/lexer.l:401
#, c-format
msgid "%s: Not found in search path"
msgstr "%s: ვერ ვიპოვე ძებნის ბილიკში"

#: src/lexer.l:410
#, c-format
msgid "%s: Failed tilde expand"
msgstr "%s: ტილდის გაშლის შეცდომა"
